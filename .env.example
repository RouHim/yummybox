# YummyBox — runtime configuration
# All variables are optional. Set only what you need.

# LLM provider API keys (set the key(s) for providers you intend to use)
# See the LLM Recipe Import section in README.md for per-provider setup.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
NEBIUS_API_KEY=
MIMO_API_KEY=
MINIMAX_API_KEY=
ZAI_API_KEY=
BIGMODEL_API_KEY=
ALIYUN_API_KEY=
BAIDU_API_KEY=
MOONSHOT_API_KEY=
AIHUBMIX_API_KEY=
OPEN_ROUTER_API_KEY=
BEDROCK_API_KEY=
GITHUB_COPILOT_API_KEY=
OPENCODE_GO_API_KEY=

# Override SQLite data directory (default: ./data relative to working directory)
YUMMYBOX_DATA_DIR=

# Tracing/log filter (default: info; set to debug for verbose output)
RUST_LOG=
